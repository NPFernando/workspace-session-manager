Screen {
    background: #282c34;
    color: #c9d8e0;
}

#log-header {
    dock: top;
    height: 3;
    padding: 1 2 0 2;
    background: #333844;
    border-bottom: solid #355a66;
    overflow: hidden;
}

#header-band {
    dock: top;
    height: auto;
}

#app-header {
    height: 3;
    padding: 1 2 0 2;
    background: #333844;
    border-bottom: solid #355a66;
    overflow: hidden;
}

.medium #app-header {
    height: 4;
}

#search-mode {
    dock: top;
    display: none;
    height: 3;
    padding: 0 2;
    background: #333844;
    border-bottom: solid #355a66;
}

.searching #search-mode {
    display: block;
}

.overlay-active #search-mode,
.overlay-active #action-bar,
.overlay-active #health-row {
    display: none;
}

#health-row {
    display: none;
    height: 2;
    padding: 0 2;
    background: #333844;
    border-bottom: solid #355a66;
}

.has-alerts #health-row {
    display: block;
}

.searching #health-row {
    display: none;
}

#search-label {
    width: 9;
    height: 3;
    padding-top: 1;
    color: #93a3ac;
}

#search {
    width: 1fr;
    height: 3;
    border: tall #3f8a9d;
    background: #23262e;
}

#search-hint {
    width: 25;
    height: 3;
    padding: 1 0 0 2;
    color: #7e8f99;
}

#workspace {
    height: 1fr;
}

#session-pane {
    width: 36%;
    min-width: 36;
    border-right: solid #355a66;
    background: #262a32;
}

.medium #session-pane {
    width: 42%;
}

#sessions {
    height: 1fr;
    padding: 0 1;
    background: #262a32;
    border: none;
    scrollbar-color: #47545c;
    scrollbar-background: #2a2e36;
}

OptionList > .option-list--option {
    padding: 0 1;
}

OptionList > .option-list--option:hover {
    background: #19242c;
}

OptionList > .option-list--option-highlighted {
    background: #2f6b7a;
    color: #ffffff;
    text-style: none;
}

OptionList > .option-list--option-disabled {
    color: #78868f;
    background: #262a32;
    padding-top: 1;
}

#detail-pane {
    width: 64%;
    min-width: 40;
    background: #282c34;
    align-horizontal: center;
}

.medium #detail-pane {
    width: 58%;
}

#identity {
    width: 100%;
    max-width: 120;
    height: auto;
    min-height: 4;
    padding: 1 2;
    background: #2e323b;
    border-bottom: solid #355a66;
}

#inspector-scroll {
    width: 100%;
    max-width: 120;
    height: 1fr;
    padding: 1 2 0 2;
    scrollbar-color: #47545c;
    scrollbar-background: #282c34;
}

#overview-status-row {
    layout: vertical;
    width: 100%;
    height: auto;
}

.very-wide #overview-status-row {
    layout: horizontal;
}

.very-wide #overview-card {
    width: 1fr;
    margin-right: 1;
}

.very-wide #status-card {
    width: 1fr;
}

.inspector-card {
    width: 100%;
    height: auto;
    min-height: 3;
    margin-bottom: 1;
    padding: 0 1 1 1;
    background: #2c3038;
    border-left: solid #3f6470;
}

.inspector-card.warning {
    border-left: solid #c5903c;
    background: #1d1b15;
}

.inspector-card.error {
    border-left: solid #c75b64;
    background: #211719;
}

.inspector-card.success {
    border-left: solid #477c59;
}

.section-title {
    height: 2;
    padding-top: 1;
    color: #8998a1;
    text-style: bold;
}

.section-body {
    height: auto;
    min-height: 1;
    color: #c7d3da;
}

#activity-card {
    min-height: 5;
}

#output-card {
    height: 1fr;
    min-height: 10;
    padding-bottom: 0;
}

#output-heading {
    height: 2;
}

#output-heading .section-title {
    width: 18;
}

.output-mode {
    width: 11;
    min-width: 11;
    height: 1;
    min-height: 1;
    margin-top: 1;
    padding: 0 1;
    border: none;
    color: #7e8f99;
    background: #2c3038;
}

.output-mode.active {
    color: #dbe6ec;
    background: #35606b;
    text-style: bold;
}

#output-meta {
    width: 1fr;
    height: 2;
    padding-top: 1;
    text-align: right;
    color: #78868f;
    overflow: hidden;
}

#recent-output-scroll {
    height: 1fr;
    min-height: 6;
    background: #1c1f26;
    border-top: solid #33414a;
    scrollbar-color: #47545c;
    scrollbar-background: #1c1f26;
}

.output-body {
    height: auto;
    min-height: 100%;
    padding: 1;
    color: #b7c4cc;
}

#actions-card {
    width: 100%;
    max-width: 120;
    height: 5;
    min-height: 5;
    margin-bottom: 0;
    padding: 0 2;
    border-top: solid #355a66;
    border-left: none;
    background: #2c3038;
}

#session-actions {
    height: 2;
    overflow: hidden;
}

#action-bar {
    dock: bottom;
    height: 2;
    padding: 0 2;
    background: #333844;
    color: #b2c0c8;
    border-top: solid #355a66;
    content-align: left middle;
    overflow: hidden;
}

#small-terminal {
    display: none;
    width: 100%;
    height: 100%;
    content-align: center middle;
    text-align: center;
    color: #c7d3da;
}

.short #identity {
    min-height: 3;
    padding: 0 2;
}

.short #inspector-scroll {
    padding-top: 0;
}

.short .inspector-card {
    margin-bottom: 0;
    padding-bottom: 0;
}

.short .section-title {
    height: 1;
    padding-top: 0;
}

.short #activity-card {
    min-height: 3;
}

.short #output-card {
    min-height: 5;
}

.short #actions-card {
    height: 3;
    min-height: 3;
}

.short #session-actions {
    height: 1;
}

.narrow #session-pane {
    width: 100%;
    min-width: 0;
    border-right: none;
}

.narrow #detail-pane {
    display: none;
}

.narrow.narrow-detail #session-pane {
    display: none;
}

.narrow.narrow-detail #detail-pane {
    display: block;
    width: 100%;
    min-width: 0;
}

.narrow.narrow-detail #inspector-scroll {
    max-width: 100%;
    padding: 0 1;
}

.narrow.narrow-detail #inspector-scroll:focus {
    border-left: solid #3f8a9d;
}

.narrow.narrow-detail #output-heading .section-title {
    width: 1fr;
}

.narrow.narrow-detail #output-meta,
.narrow.narrow-detail #actions-card {
    display: none;
}

.narrow.narrow-detail #output-card {
    min-height: 8;
}

.narrow #app-header {
    height: 2;
    padding: 0 1;
}

.narrow #action-bar {
    height: 2;
    padding: 0 1;
}

.too-small #header-band,
.too-small #app-header,
.too-small #search-mode,
.too-small #health-row,
.too-small #workspace,
.too-small #action-bar {
    display: none;
}

.too-small #small-terminal {
    display: block;
}

ModalScreen {
    align: center middle;
    background: #080a0c 70%;
}

.dialog {
    width: 68;
    max-width: 94%;
    height: auto;
    max-height: 92%;
    padding: 1 2;
    border: solid #5f8996;
    background: #333844;
    scrollbar-color: #47545c;
    scrollbar-background: #333844;
}

.create-dialog {
    width: 72;
    height: auto;
    max-height: 94%;
    padding-bottom: 0;
}

#create-dialog.advanced {
    height: 94%;
}

#create-basic {
    height: auto;
}

#create-advanced {
    height: 1fr;
    min-height: 8;
    scrollbar-color: #47545c;
    scrollbar-background: #333844;
}

.form-row {
    height: 1;
    margin-bottom: 0;
}

.task-row {
    height: 3;
}

.task-row TextArea {
    width: 1fr;
    height: 3;
    border: tall #45707d;
    background: #23262e;
}

.field-status {
    height: auto;
    min-height: 1;
    margin-left: 18;
    color: #7e8f99;
}

.field-status.valid {
    color: #72c78e;
}

.field-status.invalid,
#create-submit-reason.invalid {
    color: #ef6b73;
}

.field-status.warning {
    color: #e9b44c;
}

.field-status.checking {
    color: #7e8f99;
}

.form-row .field-label,
.preview-row .field-label,
.validation-row .field-label {
    width: 18;
    height: 1;
    margin-top: 0;
    padding-top: 0;
}

.form-row Input,
.form-row Select,
.form-row TextArea {
    width: 1fr;
}

.create-dialog Input,
.create-dialog Select {
    height: 1;
    border: none;
    background: #23262e;
}

.create-dialog Input:focus,
.create-dialog Select:focus {
    border: none;
    background: #2a3742;
    color: #dbe6ec;
}

#create-cwd {
    width: 2fr;
}

#create-recent-dir {
    width: 18;
    margin-left: 1;
}

#create-home-project {
    display: none;
    width: 20;
    min-width: 20;
    height: 1;
    margin-left: 1;
}

.preview-row {
    height: 1;
    min-height: 1;
}

.preview-row .field-label {
    height: 1;
    padding-top: 0;
}

.small-dialog {
    width: 58;
}

.manage-dialog {
    width: 72;
    height: 31;
    max-height: 94%;
    padding-bottom: 0;
}

#manage-actions {
    height: 1fr;
    min-height: 10;
    background: #292d35;
    border: none;
    scrollbar-color: #47545c;
    scrollbar-background: #333844;
}

#manage-actions > .option-list--option {
    height: 1;
    min-height: 1;
    padding: 0 1;
}

#manage-actions > .option-list--option-disabled {
    height: 1;
    min-height: 1;
    padding: 0 1;
    background: #262a32;
}

#manage-search {
    display: none;
    height: 1;
    border: none;
    background: #262a32;
}

.finding #manage-search {
    display: block;
}

#manage-detail {
    height: 3;
    min-height: 3;
    padding: 0 1;
    border-left: solid #4d7986;
    background: #2c3038;
    color: #b7c4cc;
}

#manage-help {
    height: 1;
    min-height: 1;
    margin-top: 0;
}

#manage-close-row {
    height: 1;
    min-height: 1;
    align-horizontal: right;
}

#more-cancel {
    width: 12;
    min-width: 12;
    height: 1;
    min-height: 1;
    margin-top: 0;
    border: none;
}

.narrow-manage {
    align: left top;
}

.narrow-manage .manage-dialog {
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    border: none;
}

.identity-dialog {
    width: 68;
}

.identity-dialog .field-label {
    margin-top: 0;
}

.identity-dialog Input {
    height: 1;
    border: none;
    background: #23262e;
}

.identity-dialog Input:focus {
    border: none;
    background: #2a3742;
    color: #dbe6ec;
}

.identity-dialog .field-status {
    margin-left: 0;
}

.task-dialog {
    width: 68;
    height: 18;
}

#note-value {
    height: 1fr;
    min-height: 6;
    border: tall #45707d;
    background: #23262e;
}

#note-status {
    margin-left: 0;
    text-align: right;
}

.status-dialog {
    width: 64;
}

.diagnostics-dialog {
    width: 78;
    height: 78%;
}

#diagnostics-meta {
    height: 1;
    color: #7e8f99;
}

#diagnostics-loading {
    height: 1;
    display: none;
    color: #5fc2d6;
}

.message-dialog {
    height: auto;
    max-height: 80%;
}

.dialog-title {
    height: 2;
    color: #dbe6ec;
    text-style: bold;
}

.dialog-context, .confirm-name {
    height: auto;
    margin-bottom: 1;
    color: #93a3ac;
}

.mode-help {
    height: auto;
    min-height: 1;
    margin-top: 1;
    color: #7e8f99;
}

.field-label {
    height: 1;
    margin-top: 1;
    color: #a0aeb5;
}

.secondary-field {
    color: #7d8a92;
}

.dialog Input,
.dialog Select {
    width: 100%;
}

Input:focus,
Select:focus {
    border: tall #5fc2d6;
    background: #2a2f3a;
}

Button {
    min-width: 12;
}

Button:hover {
    background: #2b3943;
}

Button:focus {
    border: tall #7fd0e0;
    text-style: bold;
}

Button:disabled {
    color: #66737b;
    background: #33373d;
    border: tall #30383d;
    text-style: none;
}

Button.-error {
    color: #fff1f2;
    background: #7f333b;
}

Button.-error:focus {
    border: tall #ff8c95;
}

#logging-row {
    height: 1;
    margin-top: 0;
}

#logging-row .field-label {
    width: 18;
    height: 1;
    margin-top: 0;
    padding-top: 0;
}

#create-logging {
    width: 8;
    height: 1;
}

#logging-state,
#prefix-state {
    width: 1fr;
    height: 1;
    color: #b7c4cc;
}

#logging-hint {
    height: 2;
    margin-left: 18;
    color: #7e8f99;
}

#command-preview,
#create-submit-reason {
    width: 1fr;
    height: auto;
    min-height: 1;
    padding: 0 1;
    background: #1c1f26;
    color: #b7c4cc;
}

#create-submit-reason {
    margin-top: 0;
    color: #7e8f99;
}

#create-summary {
    display: none;
    height: auto;
    max-height: 6;
    margin-top: 1;
    padding: 0 1;
    border-left: solid #3e6d55;
    background: #121a17;
}

#create-form-help {
    height: 1;
    color: #7e8f99;
    text-align: right;
}

#create-advanced-toggle {
    width: 26;
    min-width: 26;
    height: 1;
    min-height: 1;
    margin-left: 18;
    border: none;
    background: transparent;
    color: #93a3ac;
    text-align: left;
}

#create-advanced-toggle:focus {
    border: none;
    background: #2a3742;
    color: #7fd0e0;
}

#create-advanced.collapsed {
    display: none;
}

.field-help {
    height: 1;
    margin-left: 18;
    color: #7e8f99;
}

#create-advanced-content {
    height: auto;
}

.narrow-form {
    align: left top;
}

.narrow-form .create-dialog {
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    border: none;
}

.compact-form .create-dialog {
    height: 100%;
    max-height: 100%;
}

.compact-form #create-basic {
    height: 1fr;
    overflow-y: auto;
    scrollbar-color: #47545c;
    scrollbar-background: #333844;
}

.dialog-actions {
    height: 3;
    min-height: 3;
    align-horizontal: right;
    margin-top: 1;
}

.dialog-actions Button {
    margin-left: 1;
}

.create-dialog .dialog-actions {
    margin-top: 0;
}

.failure-actions {
    height: auto;
    min-height: 3;
}

#create-failure-dialog {
    width: 72;
}

#message-close {
    width: 100%;
    margin-top: 1;
}

.danger-dialog {
    border: solid #b94f59;
}

.danger-title {
    color: #ef6b73;
}

.confirm-copy {
    height: auto;
    margin-bottom: 1;
}

#message-content,
#onboarding-copy {
    height: auto;
    margin-bottom: 1;
}

#diagnostics-summary {
    height: 2;
    padding: 0 1;
    background: #23262e;
    color: #b7c4cc;
}

#diagnostics-list {
    height: 1fr;
    min-height: 10;
    margin-top: 1;
    padding: 1;
    background: #23262e;
}

#diagnostics-content {
    height: auto;
}

.diagnostics-actions {
    height: auto;
    min-height: 6;
}

.logs-workspace {
    background: #282c34;
}

.logs-workspace #log-header {
    height: 2;
    padding: 0 2;
    content-align: left middle;
}

#log-status {
    height: 1;
    padding: 0 2;
    background: #2c3038;
    color: #a2adb3;
    overflow: hidden;
}

#log-controls {
    height: 2;
    min-height: 2;
    padding: 0 2;
    background: #2c3038;
    border-bottom: solid #355a66;
}

#log-controls Button {
    width: 10;
    min-width: 10;
    height: 1;
    min-height: 1;
    margin-right: 1;
    border: none;
    background: #343841;
    color: #a0aeb5;
}

#log-controls Button.active {
    background: #2f6b7a;
    color: #ffffff;
    text-style: bold;
}

#log-controls Button:focus {
    border: none;
    background: #3a8494;
}

#log-controls Button:disabled {
    border: none;
    background: #2a2e36;
    color: #5d6a70;
}

#log-follow {
    width: 12;
    min-width: 12;
}

#log-output-meta {
    width: 1fr;
    height: 1;
    color: #7e8f99;
    text-align: right;
    overflow: hidden;
}

#log-alert,
#log-error {
    display: none;
    height: auto;
    min-height: 2;
    padding: 0 2;
}

.has-log-alert #log-alert {
    display: block;
    background: #302814;
    color: #f0c66c;
    border-bottom: solid #80682f;
}

.has-log-error #log-error {
    display: block;
    background: #31191c;
    color: #ef8a91;
    border-bottom: solid #8d3f47;
}

#log-find {
    display: none;
    height: 1;
    min-height: 1;
    padding: 0 2;
    background: #2a3540;
}

.finding #log-find {
    display: block;
}

#log-find-label {
    width: 7;
    color: #7fd0e0;
    text-style: bold;
}

#log-find-input {
    width: 1fr;
    height: 1;
    border: none;
    background: #23262e;
}

#log-find-input:focus {
    border: none;
    background: #2a3742;
}

#log-find-count {
    width: 14;
    padding-left: 1;
    color: #93a3ac;
    text-align: right;
}

#log-output {
    height: 1fr;
    min-height: 8;
    padding: 0 1;
    border: none;
    background: #282c34;
    color: #c3ccd2;
    scrollbar-color: #47545c;
    scrollbar-background: #282c34;
}

#log-output:focus {
    border-left: solid #3f8a9d;
    background: #23262e;
}

#log-action-bar {
    height: 2;
    min-height: 2;
    padding: 0 2;
    background: #333844;
    color: #b7c4cc;
    border-top: solid #355a66;
    overflow: hidden;
}

#log-small-terminal {
    display: none;
}

.log-narrow #log-status {
    height: 2;
}

.log-narrow #log-controls {
    height: 2;
}

.log-narrow #log-action-bar {
    height: 2;
}

.log-too-small #log-header,
.log-too-small #log-status,
.log-too-small #log-controls,
.log-too-small #log-alert,
.log-too-small #log-error,
.log-too-small #log-find,
.log-too-small #log-output,
.log-too-small #log-action-bar {
    display: none;
}

.log-too-small #log-small-terminal {
    display: block;
    width: 100%;
    height: 100%;
    padding: 3 4;
    color: #c3ccd2;
    background: #282c34;
}

.light Screen,
.light #detail-pane,
.light #inspector-scroll {
    background: #f4f6f7;
    color: #20272b;
}

.light #app-header,
.light #session-pane,
.light #action-bar,
.light #identity,
.light #actions-card {
    background: #e7ecef;
    color: #20272b;
}

.light #sessions,
.light OptionList > .option-list--option-disabled {
    background: #edf1f3;
    color: #58666e;
}

.light OptionList > .option-list--option:hover {
    background: #dce5ea;
}

.light OptionList > .option-list--option-highlighted {
    color: #ffffff;
    background: #24598a;
}

.light .inspector-card {
    background: #ffffff;
    color: #20272b;
}

.light .section-body,
.light .output-body {
    color: #20272b;
}

.light .logs-workspace,
.light #log-output,
.light #log-output:focus {
    background: #f8fafb;
    color: #20272b;
}

.light #log-header,
.light #log-status,
.light #log-controls,
.light #log-action-bar {
    background: #e7ecef;
    color: #3d4a51;
}

.light #log-find {
    background: #dce8f0;
}

.light #log-find-input,
.light #log-find-input:focus {
    background: #ffffff;
    color: #20272b;
}

.light #log-output-meta,
.light #log-find-count {
    color: #52616a;
}

.light .has-log-alert #log-alert {
    background: #fff5d7;
    color: #795700;
}

.light .has-log-error #log-error {
    background: #fdebed;
    color: #9d2633;
}

.light #recent-output-scroll,
.light #command-preview,
.light #create-submit-reason,
.light #diagnostics-list,
.light #diagnostics-summary,
.light #manage-actions,
.light #manage-detail,
.light #manage-search {
    background: #f8fafb;
    color: #20272b;
}

.light .manage-dialog,
.light .identity-dialog,
.light .task-dialog,
.light .status-dialog {
    background: #edf1f3;
    color: #20272b;
}

.light .dialog-title {
    color: #20272b;
}

.light .dialog-context,
.light .mode-help,
.light .field-label {
    color: #52616a;
}

.light .identity-dialog Input,
.light .task-dialog TextArea,
.light .status-dialog Select {
    background: #ffffff;
    color: #20272b;
}

.light .identity-dialog Input:focus,
.light .task-dialog TextArea:focus,
.light .status-dialog Select:focus {
    background: #e3edf4;
    color: #20272b;
}

.light #manage-actions > .option-list--option-disabled {
    background: #e4e9ec;
}

.monochrome Screen,
.monochrome #app-header,
.monochrome #session-pane,
.monochrome #detail-pane,
.monochrome #action-bar,
.monochrome #identity,
.monochrome .inspector-card,
.monochrome OptionList > .option-list--option-disabled {
    color: #e6e6e6;
    background: #111111;
}

.monochrome OptionList > .option-list--option-highlighted {
    color: #000000;
    background: #d7d7d7;
    text-style: bold;
}

.monochrome #recent-output-scroll,
.monochrome #command-preview,
.monochrome #create-submit-reason,
.monochrome #manage-actions,
.monochrome #manage-detail,
.monochrome #manage-search,
.monochrome #log-output,
.monochrome #log-output:focus {
    color: #e6e6e6;
    background: #080808;
}

.monochrome #log-header,
.monochrome #log-status,
.monochrome #log-controls,
.monochrome #log-action-bar,
.monochrome #log-find,
.monochrome #log-alert,
.monochrome #log-error {
    color: #e6e6e6;
    background: #111111;
}

.monochrome #log-controls Button.active {
    color: #000000;
    background: #d7d7d7;
}

.monochrome .manage-dialog,
.monochrome .identity-dialog,
.monochrome .task-dialog,
.monochrome .status-dialog,
.monochrome #manage-actions > .option-list--option-disabled {
    color: #e6e6e6;
    background: #111111;
}

