.paper .danger-title {
    color: #ef6b73;
}

.paper #diagnostics-summary {
    background: #fbf8f0;
    color: #352e26;
}

.paper #diagnostics-list {
    background: #fbf8f0;
}

.paper .logs-workspace {
    background: #f7f3e9;
}

.paper #log-status {
    background: #efe9d8;
    color: #59503f;
}

.paper #log-controls {
    background: #efe9d8;
    border-bottom: solid #ddd3b8;
}

.paper #log-controls Button {
    background: #e6dcc7;
    color: #4d4335;
}

.paper #log-controls Button.active {
    background: #8a5a2b;
    color: #ffffff;
}

.paper #log-controls Button:focus {
    background: #764a22;
}

.paper #log-controls Button:disabled {
    background: #e8ddc4;
    color: #776b57;
}

.paper #log-output-meta {
    color: #6b5f4d;
}

.paper .has-log-alert #log-alert {
    background: #302814;
    color: #f0c66c;
    border-bottom: solid #80682f;
}

.paper .has-log-error #log-error {
    background: #31191c;
    color: #ef8a91;
    border-bottom: solid #8d3f47;
}

.paper #log-find {
    background: #e6d9c0;
}

.paper #log-find-label {
    color: #a06f3a;
}

.paper #log-find-input {
    background: #fbf8f0;
}

.paper #log-find-input:focus {
    background: #ecdfc5;
}

.paper #log-find-count {
    color: #5e5240;
}

.paper #log-output {
    background: #f7f3e9;
    color: #3e352b;
    scrollbar-color: #47545c;
    scrollbar-background: #f7f3e9;
}

.paper #log-output:focus {
    border-left: solid #9a6a35;
    background: #fbf8f0;
}

.paper #log-action-bar {
    background: #efe6d3;
    color: #352e26;
    border-top: solid #ddd3b8;
}

.paper .log-too-small #log-small-terminal {
    color: #3e352b;
    background: #f7f3e9;
}
